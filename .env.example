# ══════════════════════════════════════════════════════════════════
# Окружение для docker-compose (скопировать в .env при необходимости)
# ══════════════════════════════════════════════════════════════════

# URL внешней Visary-системы (для загрузки списка проектов в UI).
# Если пусто — frontend работает только с локальным backend без Visary.
VITE_VISARY_API_URL=https://isup-alfa-test.k8s.npc.ba

# Bearer-токен для Visary API (UI и backend читают одну и ту же переменную через .env / docker-compose).
# Никогда не коммитить!
VITE_VISARY_API_TOKEN=

# ── Backend (KiloImportService.Api) ──────────────────────────────────
# Можно задать через env или прямо в appsettings.Development.json (секция "Visary").
# Пример (PowerShell): $env:Visary__BearerToken = "<jwt>"
Visary__BaseUrl=https://isup-alfa-test.k8s.npc.ba
Visary__BearerToken=
