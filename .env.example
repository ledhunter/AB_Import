# ══════════════════════════════════════════════════════════════════
# Окружение для docker-compose (скопировать в .env при необходимости)
# ══════════════════════════════════════════════════════════════════

# URL внешней Visary-системы (для загрузки списка проектов в UI).
# Если пусто — frontend работает только с локальным backend без Visary.
VITE_VISARY_API_URL=https://isup-alfa-test.k8s.npc.ba

# Bearer-токен для Visary API. Никогда не коммитить!
VITE_VISARY_API_TOKEN=
