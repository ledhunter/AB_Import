# Шаблон переменных окружения для Visary API.
# Скопируй в .env.local и заполни реальными значениями.
# .env.local в .gitignore - токен не попадёт в репозиторий.

# Базовый URL Visary API (без завершающего слэша).
VITE_VISARY_API_URL=https://isup-alfa-test.k8s.npc.ba

# Bearer-токен для авторизации в Visary API.
# Получить можно через UI Visary -> DevTools -> Network -> Authorization header.
# Токены имеют срок жизни (~1 час), при 401 нужно обновить.
VITE_VISARY_API_TOKEN=put-your-bearer-token-here
