<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>KiloImportService.Api</RootNamespace>
    <AssemblyName>KiloImportService.Api</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
  </PropertyGroup>

  <ItemGroup>
    <!-- ASP.NET Core ─ Swagger / OpenAPI / SignalR -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.7" />
    <!-- ⚠️ Версии 7.x несовместимы с .NET 10 / Microsoft.OpenApi 2.0 (OperationType удалён).
         См. doc_project/19-net10-swashbuckle.md. Пин строго на 10.1.7+. -->
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
    <PackageReference Include="Swashbuckle.AspNetCore.Annotations" Version="10.1.7" />

    <!-- EF Core 9 + Npgsql (поддерживает .NET 10 на runtime) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.4" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />

    <!-- Парсеры файлов -->
    <PackageReference Include="ClosedXML" Version="0.104.2" />              <!-- XLSX -->
    <PackageReference Include="ExcelDataReader" Version="3.7.0" />          <!-- XLS / XLSB -->
    <PackageReference Include="ExcelDataReader.DataSet" Version="3.7.0" />
    <PackageReference Include="System.Text.Encoding.CodePages" Version="9.0.4" />  <!-- CP1251 для XLS -->
    <PackageReference Include="CsvHelper" Version="33.0.1" />               <!-- CSV -->

    <!-- Логирование / observability -->
    <PackageReference Include="Serilog.AspNetCore" Version="9.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
  </ItemGroup>

</Project>
